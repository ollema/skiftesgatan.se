		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.2",
		"@vitest/browser-playwright": "^4.1.4",
		"better-auth": "~1.6.1",
		"bits-ui": "^2.17.3",
		"dotenv": "^17.4.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
