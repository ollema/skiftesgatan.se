{
	"name": "skiftesgatan",
	"private": true,
	"version": "0.0.1",
	"packageManager": "pnpm@10.24.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test": "vitest run && playwright test",
		"db:dev:push": "DATABASE_URL= drizzle-kit push --force",
		"db:dev:reset": "rm -rf .pglite",
		"db:dev:seed": "DATABASE_URL= pnpx tsx src/lib/server/db/seed/timeslots.ts && DATABASE_URL= pnpx tsx src/lib/server/db/seed/accounts.ts && DATABASE_URL= pnpx tsx src/lib/server/db/seed/bookings.ts",
		"db:dev:seed:timeslots": "DATABASE_URL= pnpx tsx src/lib/server/db/seed/timeslots.ts",
		"db:dev:seed:accounts": "DATABASE_URL= pnpx tsx src/lib/server/db/seed/accounts.ts",
		"db:dev:seed:bookings": "DATABASE_URL= pnpx tsx src/lib/server/db/seed/bookings.ts",
		"db:dev:studio": "DATABASE_URL= drizzle-kit studio",
		"db:dev:fresh": "pnpm db:dev:reset && pnpm db:dev:push && pnpm db:dev:seed",
		"db:test:push": "DATABASE_URL= PGLITE_PATH=.pglite-test drizzle-kit push --force",
		"db:test:reset": "rm -rf .pglite-test .test-emails",
		"db:test:seed": "DATABASE_URL= PGLITE_PATH=.pglite-test pnpx tsx src/lib/server/db/seed/timeslots.ts && DATABASE_URL= PGLITE_PATH=.pglite-test pnpx tsx src/lib/server/db/seed/accounts.ts",
		"db:test:fresh": "pnpm db:test:reset && pnpm db:test:push && pnpm db:test:seed",
		"db:prod:tunnel": "pnpx tsx scripts/db-prod.ts tunnel",
		"db:prod:push": "pnpx tsx scripts/db-prod.ts push",
		"db:prod:migrate": "pnpx tsx scripts/db-prod.ts migrate",
		"db:prod:studio": "pnpx tsx scripts/db-prod.ts studio",
		"db:prod:seed:timeslots": "pnpx tsx scripts/db-prod.ts seed:timeslots",
		"db:prod:seed:accounts": "pnpx tsx scripts/db-prod.ts seed:accounts",
		"db:generate": "drizzle-kit generate",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"knip": "knip"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@content-collections/core": "^0.14.3",
		"@content-collections/markdown": "^0.1.4",
		"@content-collections/vite": "^0.2.9",
		"@electric-sql/pglite": "^0.4.2",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@playwright/test": "^1.59.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"@vitest/browser-playwright": "^4.1.2",
		"better-auth": "~1.5.6",
		"bits-ui": "^2.16.5",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-better-tailwindcss": "^4.3.2",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"knip": "^6.1.1",
		"playwright": "^1.59.0",
		"postgres": "^3.4.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"resend": "^6.10.0",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"valibot": "^1.3.1",
		"vite": "^8.0.3",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.0"
	}
}
