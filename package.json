{
	"name": "skiftesgatan",
	"private": true,
	"version": "0.0.1",
	"packageManager": "pnpm@10.33.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test": "vitest run && playwright test",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"db:reset": "pnpx tsx scripts/db/reset.ts",
		"db:seed": "pnpx tsx scripts/db/seed.ts",
		"db:studio": "pnpx tsx scripts/db/studio.ts",
		"db:tunnel": "pnpx tsx scripts/db/tunnel.ts",
		"knip": "knip",
		"icons": "pnpx tsx scripts/generate-icons.ts"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@clack/prompts": "^1.2.0",
		"@content-collections/core": "^0.14.3",
		"@content-collections/markdown": "^0.1.4",
		"@content-collections/vite": "^0.2.9",
		"@electric-sql/pglite": "^0.4.3",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
