		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"valibot": "^1.3.1",
		"vite": "^8.0.8",
